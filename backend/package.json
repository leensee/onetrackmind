    "test:gate": "tsx --tsconfig tsconfig.test.json tests/approvalGate.test.ts",
    "test:router": "tsx --tsconfig tsconfig.test.json tests/outputRouter.test.ts",
    "test:persistence": "tsx --tsconfig tsconfig.test.json tests/sessionPersistence.test.ts",
