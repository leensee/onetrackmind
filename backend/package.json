    "test:content-hash": "tsx --tsconfig tsconfig.test.json tests/contentHash.test.ts",
    "test:idempotency": "tsx --tsconfig tsconfig.test.json tests/idempotencyChecker.test.ts",
    "test:comms-log-writer": "tsx --tsconfig tsconfig.test.json tests/commsLogWriter.test.ts",
    "typecheck": "tsc --project tsconfig.test.json --noEmit"
